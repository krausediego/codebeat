{
  "name": "@repo/api",
  "version": "1.0.50",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "bun run --watch src/server.ts | pino-pretty --messageKey message --ignore severity",
    "db:generate": "bun --env-file .env --bun drizzle-kit generate",
    "db:migrate": "bun --env-file .env --bun drizzle-kit migrate",
    "generate": "bun scripts/generate-module.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "elysia": "^1.4.25",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@repo/tsconfig": "*",
    "bun-types": "latest",
    "pino-pretty": "^13.1.3"
  },
  "module": "src/index.js"
}